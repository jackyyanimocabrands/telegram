meta {
  name: Get Token Usage by Conversation
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/admin/token-usage/conversation/:botId/:userId
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminApiKey}}
}

params:path {
  botId: your-bot-id
  userId: 123456789
}

params:query {
  ~from: 2026-01-01T00:00:00Z
  ~to: 2026-12-31T23:59:59Z
}

docs {
  Returns aggregated token usage for a single (botId, telegramUserId) conversation,
  grouped by provider, model, and usage_type.

  Path params:
  - botId   string  — the bot's internal ID
  - userId  number  — Telegram user ID (integer)

  Optional query params:
  - from    ISO date string
  - to      ISO date string

  Response fields per row:
  - provider               string
  - model                  string
  - usage_type             "chat" | "summarization"
  - total_input_tokens     string  (bigint as string)
  - total_output_tokens    string  (bigint as string)
  - sum_total_tokens       string  (bigint as string)
  - call_count             string  (bigint as string)
}
