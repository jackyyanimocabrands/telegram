# ── Telegram (single bot for login + management) ──
BOT_TOKEN=
BOT_USERNAME=
# Min 32 chars, alphanumeric + _ - only
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=
CHILD_WEBHOOK_SECRET=

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hellominds_connector

# ── Encryption ──
# 32-byte hex string (64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=
# Bump to re-encrypt tokens under a new key; old version still decrypts during rotation
ENCRYPTION_KEY_VERSION=1

# ── JWT (ES256 asymmetric) ──
# Generate keypair:
#   openssl ecparam -name prime256v1 -genkey -noout -out ec-private.pem
#   openssl ec -in ec-private.pem -pubout -out ec-public.pem
# Paste as single-line PEM strings (use \n for newlines)
ES256_PRIVATE_KEY=
ES256_PUBLIC_KEY=
# Access token TTL in seconds (default: 2592000 = 30 days)
JWT_EXPIRES_IN=2592000
# Refresh token TTL in seconds (default: 604800 = 7 days)
JWT_REFRESH_EXPIRES_IN=604800
# Global token version — bump to invalidate ALL issued tokens across all users
JWT_VERSION=1

# ── CORS ──
# Comma-separated list of allowed origins (e.g. https://app.example.com,https://admin.example.com)
# Leave empty / omit to allow all origins in development, deny all in production
CORS_ORIGINS=

# ── Server ──
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000
LOG_LEVEL=info
# Directory for log files (default: logs)
LOG_DIR=logs

# ── Runtime ──
# development | production | test
NODE_ENV=production

# ── Update Mode ──
# auto | polling | webhook
# auto resolves to "webhook" in production and "polling" in development
MANAGER_UPDATE_MODE=auto

# ── LLM Providers ──
# API keys for each provider — only the key(s) matching slots in config/llm.json are required.
# Provider + model selection is driven by config/llm.json (not env vars).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Optional: override the path to the LLM config JSON (default: config/llm.json)
# LLM_CONFIG_PATH=config/llm.json

# ── Manager Bot System Prompts (optional) ──
# Override the default system prompts for the manager bot.
# Supported placeholders:
#   Onboarding mode: {name} (user's first name), {deepLink} (bot creation URL)
#   Settings mode:   {name} (user's first name), {botUsername} (active bot @username)
# If unset, built-in defaults are used.
# MANAGER_ONBOARDING_PROMPT=You are an onboarding assistant. Help {name} create their AI agent. Share: {deepLink}
# MANAGER_SETTINGS_PROMPT=You are a platform assistant for {name}. Their bot @{botUsername} handles conversations.

# ── Streaming ──
# Minimum ms between sendMessageDraft calls (0 = no throttle, send every token; 500 = recommended)
STREAM_THROTTLE_MS=0

# ── Redis ──
REDIS_URL=redis://localhost:6379
# Minimum ms between manager bot responses per user (0 = disabled)
MANAGER_THROTTLE_MS=5000

# ── Worker ──
WORKER_CONCURRENCY=4
# How long completed/failed jobs are retained in Redis (hours)
JOB_RETENTION_HOURS=24
# Conversation lock TTL in seconds — prevents duplicate processing of concurrent messages
LOCK_TTL_SECS=60

# ── Admin API ──
# Bearer token for /admin/* endpoints — min 32 chars
# Generate: pnpm generate-api-key
ADMIN_API_KEY=
# Rate limit window in milliseconds (default: 900000 = 15 min)
# For local dev, set to 60000 (1 min) with a higher max
ADMIN_RATE_LIMIT_WINDOW_MS=900000
# Max requests per window per IP (default: 15)
ADMIN_RATE_LIMIT_MAX=15

# Tool system
BOT_MGMT_API_URL=https://your-bot-mgmt-api.example.com
BOT_MGMT_API_KEY=change-me-min-32-chars-xxxxxxxxxxxxxxxxx
SES_REGION=us-east-1
SES_FROM_ADDRESS=noreply@example.com
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
EXA_API_KEY=change-me
WEBFETCH_RATE_LIMIT_MAX=10
WEBFETCH_RATE_LIMIT_WINDOW_MS=60000
WEBFETCH_DOMAIN_ALLOWLIST=
EMAIL_VERIFICATION_TOKEN_TTL_SECS=86400
