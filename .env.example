# ── Telegram (single bot for login + management) ──
BOT_TOKEN=
BOT_USERNAME=
WEBHOOK_SECRET=
CHILD_WEBHOOK_SECRET=

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hellominds_connector

# ── Encryption ──
# 32-byte hex string: run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
ENCRYPTION_MASTER_KEY=
ENCRYPTION_KEY_VERSION=1

# ── JWT (ES256 asymmetric) ──
# Generate with:
#   openssl ecparam -name prime256v1 -genkey -noout -out ec-private.pem
#   openssl ec -in ec-private.pem -pubout -out ec-public.pem
# Paste as single-line strings (use \n for newlines)
ES256_PRIVATE_KEY=
ES256_PUBLIC_KEY=
# Token TTL in seconds (default: 2592000 = 30 days)
JWT_EXPIRES_IN=2592000
# Global token version — bump to invalidate ALL issued tokens
JWT_VERSION=1

# ── CORS ──
# Comma-separated list of allowed origins (e.g. https://app.example.com)
# Leave empty / omit to allow all origins in development, deny all in production
CORS_ORIGINS=

# ── Server ──
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000
LOG_LEVEL=info

# ── Runtime ──
# development | production
NODE_ENV=production

# ── Update Mode ──
# auto | polling | webhook
# auto resolves to "webhook" in production and "polling" in development
MANAGER_UPDATE_MODE=auto

# ── LLM Providers ──
# At least one API key is required (matching DEFAULT_LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_SUMMARIZATION_PROVIDER=openai
DEFAULT_SUMMARIZATION_MODEL=gpt-4o-mini
# FALLBACK_LLM_PROVIDER=
# FALLBACK_LLM_MODEL=

# ── Manager Bot System Prompts (optional) ──
# Override the default system prompts for the manager bot.
# Supported placeholders:
#   Onboarding mode: {name} (user's first name), {deepLink} (bot creation URL)
#   Settings mode:   {name} (user's first name), {botUsername} (active bot @username)
# If unset, built-in defaults are used.
# MANAGER_ONBOARDING_PROMPT=You are an onboarding assistant for HelloMinds. Help {name} create their personal AI agent. Share this link when ready: {deepLink}
# MANAGER_SETTINGS_PROMPT=You are a platform assistant for {name}. Their bot @{botUsername} handles conversations. Help with settings and billing.

# Streaming throttle — minimum ms between sendMessageDraft calls (0 = full throttle, send every token)
# STREAM_THROTTLE_MS=500

# Redis (for per-conversation throttle)
REDIS_URL=redis://localhost:6379
# Manager bot throttle — minimum ms between messages per user (0 = disabled)
MANAGER_THROTTLE_MS=5000

# Worker
WORKER_CONCURRENCY=4
JOB_RETENTION_HOURS=24
LOCK_TTL_SECS=60
