{
  "name": "@animocabrands/animocamind-telegram-connector",
  "version": "0.1.0",
  "description": "Telegram connector for Animocamind — login widget, managed bot provisioning, per-user bot lifecycle",
  "main": "dist/index.js",
  "author": "Animoca Brands",
  "license": "UNLICENSED",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:cli": "tsx watch src/cli/index.ts start",
    "build": "tsc",
    "start": "node dist/cli/index.js start",
    "test": "mocha",
    "test:watch": "mocha --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "tsx src/db/migrate.ts",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "verify-manager": "tsx scripts/verify-manager.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.29",
    "@langchain/core": "^1.1.46",
    "@langchain/deepseek": "^1.0.25",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/openai": "^1.4.5",
    "@langchain/openrouter": "^0.2.4",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/chai": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "@types/sinon": "^17.0.0",
    "@types/supertest": "^6.0.3",
    "chai": "^5.1.0",
    "eslint": "^9.25.0",
    "esmock": "^2.6.0",
    "mocha": "^11.0.0",
    "prettier": "^3.5.3",
    "sinon": "^19.0.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.31.0"
  }
}
